programa
{
    funcao inicio()
    {
        real n1, n2, n3, n4, diferenca

        escreva("Digite o número 1: ")
        leia(n1)

        escreva("Digite o número 2: ")
        leia(n2)

        escreva("Digite o número 3: ")
        leia(n3)

        escreva("Digite o número 4: ")
        leia(n4)

        diferenca = (n1 * n2) - (n3 * n4)

        escreva("\nDiferença: ", diferenca)
    }
}
